{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/login/?(?:/__data.json)?$",
			"dest": "/login"
		},
		{
			"src": "^/logout/?(?:/__data.json)?$",
			"dest": "/logout"
		},
		{
			"src": "^/register/?(?:/__data.json)?$",
			"dest": "/register"
		},
		{
			"src": "^/tab/demo/?(?:/__data.json)?$",
			"dest": "/tab/demo"
		},
		{
			"src": "^/tab/new/?(?:/__data.json)?$",
			"dest": "/tab/new"
		},
		{
			"src": "^/tab/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/tab/[id]"
		},
		{
			"src": "^/tab/([^/]+?)/edit/?(?:/__data.json)?$",
			"dest": "/tab/[id]/edit"
		},
		{
			"src": "^/u/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/u/[username]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}